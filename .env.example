# Environment Configuration

# Application
APP_NAME="MRI Super-Resolution API"
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Database (psycopg2 driver — matches requirements.txt)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/mri_sr_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
MAX_UPLOAD_SIZE=524288000  # 500MB in bytes

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# mri_sr_pipeline (bundled inside mri-backend; Docker mounts at /app/mri_sr_pipeline)
PIPELINE_DIR=./mri_sr_pipeline
PIPELINE_CONFIG=./mri_sr_pipeline/configs/config.yaml
TEMPLATE_DIR=./mri_sr_pipeline/data/templates

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Path (legacy placeholder)
MODEL_PATH=./models/best_model.pth
RESSSRDIFF_CHECKPOINT_DIR=../model/Res-SRDiff
RESSSRDIFF_REGION=prostate

# Processing
MAX_CONCURRENT_JOBS=2
